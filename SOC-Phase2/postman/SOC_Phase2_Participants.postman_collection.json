            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Hassan\",\n  \"email\": \"sara.hassan@example.com\",\n  \"role\": \"student\",\n  \"phone\": \"+201112345678\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/participants",
              "host": ["{{gateway_url}}"],
              "path": ["participants"]
