  "item": [
    {
      "name": "Get Dashboard Stats",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Has required fields\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"totalSessions\");",
              "  pm.expect(json).to.have.property(\"upcomingSessions\");",
              "  pm.expect(json).to.have.property(\"completedSessions\");",
              "  pm.expect(json).to.have.property(\"totalParticipants\");",
              "  pm.expect(json).to.have.property(\"topTemplate\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/dashboard/stats",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dashboard",
            "stats"
          ]
        }
      },
      "response": []
    }
  ],
